# Illustrate AI Environment Variables
# Copy this file to .env and fill in your values

# ==================== API Configuration ====================
# Choose ONE of the following options:

# Option 1: Gemini API Key (simple, but has daily limits)
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Option 2: Vertex AI (recommended for production - no daily limits, pay-per-use)
# SETUP STEPS:
#   1. Create a GCP project with billing enabled
#   2. Enable the Vertex AI API: gcloud services enable aiplatform.googleapis.com
#   3. Authenticate: gcloud auth application-default login
#   4. Set GOOGLE_GENAI_USE_VERTEXAI=true below
#
# ALTERNATIVE AUTH (for production/CI):
#   - Create a service account with "Vertex AI User" role
#   - Download JSON key and set: GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
#
# See VERTEX_AI_QUESTIONS.md for quota configuration and rate limit tuning
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false

# ==================== Database (Railway provides these) ====================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ==================== Storage (Railway provides these) ====================

# Railway Bucket settings
BUCKET=your-bucket-name
BUCKET_ACCESS_KEY_ID=your-access-key
BUCKET_SECRET_ACCESS_KEY=your-secret-key
BUCKET_ENDPOINT=https://storage.railway.app
BUCKET_REGION=auto

# ==================== Security ====================

# JWT secret for authentication (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Encryption key for API key storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-encryption-key

# ==================== Image Backend ====================
# Choose "gemini" (default) or "openai" for image generation
# Gemini: Uses Gemini 3 Pro Image models (included with Vertex AI / AI Studio)
# OpenAI: Uses GPT-Image-1 models (requires separate OpenAI API key)
IMAGE_BACKEND=gemini

# ==================== OpenAI Configuration ====================
# Required only if IMAGE_BACKEND=openai
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Batch API (50% cheaper, async processing — recommended for production)
# Set to false for synchronous mode (faster turnaround, higher cost)
OPENAI_BATCH_ENABLED=true

# ==================== Service URLs ====================

# API URL for Streamlit to call FastAPI
# Local: http://localhost:8000
# Railway internal: http://api.railway.internal:8000
API_URL=http://localhost:8000
